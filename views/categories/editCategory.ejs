<!DOCTYPE html>
<html>
<head>
    <title>Edit Category</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="page">

<div class="container">

<h2 class="page-title">Edit Category</h2>
<a class="btn back-btn" href="/">Back to Category</a>

<%- include('../partials/errors', { errors: errors }) %>

<form class="form-card" action="/categories/details/<%= category.id %>" method="POST">
  
  <div class="form-group">
    <label for="name">Name:</label>
    <input class="input-field" type="text" name="name" value="<%= category.name %>" />
  </div>

  <div class="form-group">
    <label for="description">Description:</label>
    <textarea class="input-field textarea-field" name="description"><%= category.description %></textarea>
  </div>

  <button class="btn edit" type="submit">Update</button>

</form>

</div>

</body>
</html>