<!DOCTYPE html>
<html>
    <header>
        <title>Musical Instrument Inventory</title>
        <link rel="stylesheet" href="/styles.css">
    </header>
    <body class="page">

        <div class="container">
            <h2>Musical Instrument Inventory</h2>
            <a class="btn add-btn" href="/categories/new">+ Add New Category</a>
            <h3>Categories:</h3>

            <% categories.forEach(category => { %>
            <div class="card">
                <h4 class="card-title"><%= category.name %></h4>

                <div class="actions">
                    <a class="btn view" href="/categories/details/<%= category.id %>">View</a>
                    <a class="btn edit" href="/categories/details/<%= category.id %>/edit">Edit</a>

                    <form action="/categories/<%= category.id %>/delete" method="POST">
                        <button class="btn delete" type="submit">Delete</button>
                    </form>
                </div>
            </div>
            <% }) %>

            
        </div>

    </body>
</html>