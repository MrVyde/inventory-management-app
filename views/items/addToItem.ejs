<!DOCTYPE html>
<html>
<head>
    <title>Add Item</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="page">

<div class="container">

<h2 class="page-title">Add New Item</h2>

<%- include('../partials/errors', { errors: errors }) %>

<form class="form-card" action="/items/submit" method="POST">

  <div class="form-group">
    <label for="name">Name:</label>
    <input 
      class="input-field"
      type="text"
      name="name"
      placeholder="Item Name"
      value="<%= name %>"
    />
  </div>

  <div class="form-group">
    <label for="description">Description:</label>
    <textarea 
      class="input-field textarea-field"
      name="description"
      placeholder="Item Description"
    ><%= description %></textarea>
  </div>

  <div class="form-group">
    <label for="price">Price:</label>
    <input 
      class="input-field"
      type="number"
      step="0.01"
      name="price"
      placeholder="Price"
      value="<%= price %>"
    />
  </div>

  <div class="form-group">
    <label for="quantity">Quantity:</label>
    <input 
      class="input-field"
      type="number"
      name="quantity"
      placeholder="Quantity"
      value="<%= quantity %>"
    />
  </div>

  <div class="form-group">
    <label for="categoryId">Category ID:</label>
    <input 
      class="input-field"
      type="number"
      name="categoryId"
      value="<%= categoryId || '' %>"
    />
  </div>

  <button class="btn add-btn" type="submit">Add Item</button>

</form>

<br>

<a class="btn back-btn" href="/categories/details/<%= categoryId %>">Back to Category</a>

</div>

</body>
</html>